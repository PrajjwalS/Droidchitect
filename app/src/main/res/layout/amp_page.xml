<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_main"
    android:padding="8dp">
    <!-- ================= VOICE GRID (2 x 3 UNIFORM) ================= -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="6dp">

        <!-- ROW 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:includeFontPadding="false"
            >

            <Button
                android:id="@+id/voice_clean_warm"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Clean Warm"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:layout_margin="4dp"
                android:backgroundTint="#1f1f1f"
                android:gravity="center"
                android:lines="2"
                android:ellipsize="end"
                android:textAlignment="center"
                android:includeFontPadding="false"/>

            <Button
                android:id="@+id/voice_clean_bright"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Clean Bright"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:layout_margin="4dp"
                android:backgroundTint="#1f1f1f"
                android:gravity="center"
                android:lines="2"
                android:ellipsize="end"
                android:textAlignment="center"
                android:includeFontPadding="false"/>

            <Button
                android:id="@+id/voice_crunch"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Crunch"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:layout_margin="4dp"
                android:backgroundTint="#1f1f1f"
                android:gravity="center"
                android:lines="2"
                android:ellipsize="end"
                android:textAlignment="center"
                android:includeFontPadding="false"/>

        </LinearLayout>

        <!-- ROW 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:includeFontPadding="false"
            >


            <Button
                android:id="@+id/voice_super_crunch"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Super Crunch"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:layout_margin="4dp"
                android:backgroundTint="#1f1f1f"
                android:gravity="center"
                android:lines="2"
                android:ellipsize="end"
                android:textAlignment="center"
                android:includeFontPadding="false"/>

            <Button
                android:id="@+id/voice_od1"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="OD1"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:layout_margin="4dp"
                android:backgroundTint="#1f1f1f"
                android:gravity="center"
                android:lines="2"
                android:ellipsize="end"
                android:textAlignment="center"
                android:includeFontPadding="false"/>

            <Button
                android:id="@+id/voice_od2"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="OD2"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:layout_margin="4dp"
                android:backgroundTint="#1f1f1f"
                android:gravity="center"
                android:lines="2"
                android:ellipsize="end"
                android:textAlignment="center"
                android:includeFontPadding="false"/>

        </LinearLayout>

    </LinearLayout>


    <!-- ================= KNOBS (ONLY WEIGHTED SECTION) ================= -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- ROW 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">


            <com.rejowan.rotaryknob.RotaryKnob
                android:id="@+id/knob_bass"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_margin="2dp"
                android:layout_weight="1"
                android:padding="8dp"
                app:label_margin="@dimen/knob_label_margin"
                app:label_text="BASS"
                app:max="100"
                app:min="0"
                app:show_label="true"
                app:show_progress_text="true"

                app:circle_style="gradient"
                app:circle_gradient_outer_color="#121212"
                app:circle_gradient_center_color="#2A2A2A"

                app:border_color="#2A2A2A"

                app:progress_style="circle"
                app:progress_color="#2A2A2A"
                app:progress_filled_color="#FF7A00"

                app:show_big_progress="false"
                app:progress_text_size="16dp"
                app:current_progress="50"
                app:indicator_style="line"
                app:indicator_color="#FF7A00"
                />

            <com.rejowan.rotaryknob.RotaryKnob
                android:id="@+id/knob_middle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_margin="2dp"
                android:layout_weight="1"
                android:padding="8dp"
                app:label_margin="@dimen/knob_label_margin"
                app:label_text="MIDDLE"
                app:max="100"
                app:min="0"
                app:show_label="true"
                app:show_progress_text="true"
                app:circle_style="gradient"
                app:circle_gradient_outer_color="#121212"
                app:circle_gradient_center_color="#2A2A2A"

                app:border_color="#2A2A2A"

                app:progress_style="circle"
                app:progress_color="#2A2A2A"
                app:progress_filled_color="#FF7A00"

                app:show_big_progress="false"
                app:progress_text_size="16dp"
                app:current_progress="50"
                app:indicator_style="line"
                app:indicator_color="#FF7A00"
                />

            <com.rejowan.rotaryknob.RotaryKnob
                android:id="@+id/knob_treble"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_margin="2dp"
                android:layout_weight="1"
                android:padding="8dp"
                app:label_margin="@dimen/knob_label_margin"
                app:label_text="TREBLE"
                app:max="100"
                app:min="0"
                app:show_label="true"
                app:show_progress_text="true"
                app:circle_style="gradient"
                app:circle_gradient_outer_color="#121212"
                app:circle_gradient_center_color="#2A2A2A"

                app:border_color="#2A2A2A"

                app:progress_style="circle"
                app:progress_color="#2A2A2A"
                app:progress_filled_color="#FF7A00"

                app:show_big_progress="false"
                app:progress_text_size="16dp"
                app:current_progress="50"
                app:indicator_style="line"
                app:indicator_color="#FF7A00"
                />

        </LinearLayout>

        <!-- ROW 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <!-- Repeat 4 knobs -->
            <com.rejowan.rotaryknob.RotaryKnob
                android:id="@+id/knob_isf"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_weight="1"
                android:layout_margin="2dp"
                android:padding="8dp"
                app:label_text="ISF"
                app:max="100"
                app:min="0"

                app:show_label="true"
                app:show_progress_text="true"
                app:label_margin="@dimen/knob_label_margin"
                app:circle_style="gradient"
                app:circle_gradient_outer_color="#121212"
                app:circle_gradient_center_color="#2A2A2A"

                app:border_color="#2A2A2A"

                app:progress_style="circle"
                app:progress_color="#2A2A2A"
                app:progress_filled_color="#FF7A00"

                app:show_big_progress="false"
                app:progress_text_size="16dp"
                app:current_progress="50"
                app:indicator_style="line"
                app:indicator_color="#FF7A00"
                />


            <com.rejowan.rotaryknob.RotaryKnob
                android:id="@+id/knob_presence"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_weight="1"
                android:layout_margin="2dp"
                android:padding="8dp"
                app:label_text="PRESENCE"
                app:max="100"
                app:min="0"
                app:show_label="true"
                app:show_progress_text="true"
                app:label_margin="@dimen/knob_label_margin"
                app:circle_style="gradient"
                app:circle_gradient_outer_color="#121212"
                app:circle_gradient_center_color="#2A2A2A"


                app:border_color="#2A2A2A"

                app:progress_style="circle"
                app:progress_color="#2A2A2A"
                app:progress_filled_color="#FF7A00"

                app:show_big_progress="false"
                app:progress_text_size="16dp"
                app:current_progress="50"
                app:indicator_style="line"
                app:indicator_color="#FF7A00"

                />


            <com.rejowan.rotaryknob.RotaryKnob
                android:id="@+id/knob_resonance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_weight="1"
                android:layout_margin="2dp"
                android:padding="8dp"
                app:label_text="RESONANCE"
                app:max="100"
                app:min="0"
                app:show_label="true"
                app:show_progress_text="true"
                app:label_margin="@dimen/knob_label_margin"
                app:circle_style="gradient"
                app:circle_gradient_outer_color="#121212"
                app:circle_gradient_center_color="#2A2A2A"

                app:border_color="#2A2A2A"

                app:progress_style="circle"
                app:progress_color="#2A2A2A"
                app:progress_filled_color="#FF7A00"

                app:show_big_progress="false"
                app:progress_text_size="16dp"
                app:current_progress="50"
                app:indicator_style="line"
                app:indicator_color="#FF7A00"

                />
        </LinearLayout>

        <!-- ROW 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <com.rejowan.rotaryknob.RotaryKnob
                android:id="@+id/knob_gain"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_margin="2dp"
                android:layout_weight="1"
                android:padding="8dp"
                app:label_margin="@dimen/knob_label_margin"
                app:label_text="GAIN"
                app:max="100"
                app:min="0"
                app:show_label="true"
                app:show_progress_text="true"

                app:circle_style="gradient"
                app:circle_gradient_outer_color="#121212"
                app:circle_gradient_center_color="#2A2A2A"

                app:border_color="#2A2A2A"

                app:progress_style="circle"
                app:progress_color="#2A2A2A"
                app:progress_filled_color="#FF7A00"

                app:show_big_progress="false"
                app:progress_text_size="16dp"
                app:current_progress="50"
                app:indicator_style="line"
                app:indicator_color="#FF7A00"
                />

            <com.rejowan.rotaryknob.RotaryKnob
                android:id="@+id/knob_volume"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_margin="2dp"
                android:layout_weight="1"
                android:padding="8dp"
                app:label_margin="@dimen/knob_label_margin"
                app:label_text="VOLUME"
                app:max="100"
                app:min="0"
                app:show_label="true"
                app:show_progress_text="true"
                app:circle_style="gradient"
                app:circle_gradient_outer_color="#121212"
                app:circle_gradient_center_color="#2A2A2A"

                app:border_color="#2A2A2A"

                app:progress_style="circle"
                app:progress_color="#2A2A2A"
                app:progress_filled_color="#FF7A00"

                app:show_big_progress="false"
                app:progress_text_size="16dp"
                app:current_progress="50"
                app:indicator_style="line"
                app:indicator_color="#FF7A00"

                />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>